#
# ~/.exports: Environment for both bash(1) and zsh(1).
#

#
# Prevent Ansible from looking ridiculous.
#
export ANSIBLE_NOCOWS=1

#
# Simple fork-free OS detection routine.
#
if [[ -x /sbin/kldstat ]]; then
	export BASIL_DOTFILES_KERNEL=FreeBSD
elif [[ -x /sbin/lsmod ]]; then
	export BASIL_DOTFILES_KERNEL=Linux
elif [[ -x /usr/sbin/kextstat ]]; then
	export BASIL_DOTFILES_KERNEL=Darwin
elif [[ -x /usr/sbin/modinfo ]]; then
	export BASIL_DOTFILES_KERNEL=SunOS
fi

#
# Make vim(1) the default editor.
#
export EDITOR=nvim

#
# Make less more friendly for non-text input files; see lesspipe(1).
#
[[ -x /usr/bin/lesspipe ]] && eval "$(lesspipe)"

#
# Set colors for less(1). Borrowed from:
#
#     https://wiki.archlinux.org/index.php/Color_output_in_console#less
#
export LESS_TERMCAP_mb=$'\E[1;31m'     # begin blink
export LESS_TERMCAP_md=$'\E[1;36m'     # begin bold
export LESS_TERMCAP_me=$'\E[0m'        # reset bold/blink
export LESS_TERMCAP_so=$'\E[01;44;33m' # begin reverse video
export LESS_TERMCAP_se=$'\E[0m'        # reset reverse video
export LESS_TERMCAP_us=$'\E[1;32m'     # begin underline
export LESS_TERMCAP_ue=$'\E[0m'        # reset underline

#
# If we have GNU dircolors, invoke it to set LS_COLORS.
#
if [[ -x /opt/homebrew/bin/gdircolors ]]; then
	eval "$(/opt/homebrew/bin/gdircolors -b ~/.dircolors)"
elif [[ -x /usr/bin/dircolors ]]; then
	eval "$(/usr/bin/dircolors -b ~/.dircolors)"
elif [[ -x /usr/gnu/bin/dircolors ]]; then
	eval "$(/usr/gnu/bin/dircolors -b ~/.dircolors)"
elif [[ -x /usr/local/bin/gdircolors ]]; then
	eval "$(/usr/local/bin/gdircolors -b ~/.dircolors)"
fi

#
# Don't clear the screen after quitting a manual page.
#
export MANPAGER='less -X'

#
# Set PATH so it includes user's private bin if it exists.
#
if [[ -d ~/.local/bin ]]; then
	export PATH=~/.local/bin:$PATH
fi

#
# JetBrains Toolbox
#
if [[ -d ~/.local/share/JetBrains/Toolbox/scripts ]]; then
	export PATH=~/.local/share/JetBrains/Toolbox/scripts:$PATH
fi

#
# Make Python use UTF-8 encoding for output to stdin, stdout, and stderr.
#
export PYTHONIOENCODING=UTF-8

#
# Use a color terminal.
#
if [[ -f /lib/terminfo/x/xterm-256color || -f /usr/share/terminfo/x/xterm-256color || -f /usr/share/lib/terminfo/x/xterm-256color ]]; then
	export TERM='xterm-256color'
elif [[ -f /lib/terminfo/x/xterm-color || -f /usr/share/terminfo/x/xterm-color || -f /usr/share/lib/terminfo/x/xterm-color ]]; then
	export TERM='xterm-color'
fi

#
# Better than nano.
#
export SYSTEMD_EDITOR=vim

#
# Bun
#
if [[ -d ~/.bun ]]; then
	export BUN_INSTALL="${HOME}/.bun"
	export PATH="${BUN_INSTALL}/bin:$PATH"
fi
